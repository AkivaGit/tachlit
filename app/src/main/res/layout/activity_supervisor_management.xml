<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>
        <!-- Data binding variables can be added here later -->
    </data>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/background_color"
        tools:context=".SupervisorManagementActivity">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Statistics Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="@color/surface_color"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="סטטיסטיקות"
                        android:textColor="@color/main_color"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="12dp"
                        android:gravity="center" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:weightSum="3">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center">

                            <TextView
                                android:id="@+id/tvLearnersCount"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0"
                                android:textColor="@color/main_color"
                                android:textSize="24sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="לומדים"
                                android:textColor="@color/text_secondary"
                                android:textSize="14sp" />

                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center">

                            <TextView
                                android:id="@+id/tvTeachersCount"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0"
                                android:textColor="@color/secondary_color"
                                android:textSize="24sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="מורים"
                                android:textColor="@color/text_secondary"
                                android:textSize="14sp" />

                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center">

                            <TextView
                                android:id="@+id/tvPairingsCount"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0"
                                android:textColor="@color/success_color"
                                android:textSize="24sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="שיבוצים"
                                android:textColor="@color/text_secondary"
                                android:textSize="14sp" />

                        </LinearLayout>

                    </LinearLayout>

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- Action Buttons -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="16dp">

                <Button
                    android:id="@+id/btnSuggestMatches"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:text="הצע התאמות"
                    android:backgroundTint="@color/warning_color"
                    android:textColor="@color/white"
                    android:textSize="14sp" />

                <Button
                    android:id="@+id/btnFilterByCity"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:text="סנן לפי עיר"
                    android:backgroundTint="@color/secondary_color"
                    android:textColor="@color/white"
                    android:textSize="14sp" />

            </LinearLayout>

            <!-- Learners Section -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardViewLearners"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="@color/card_learn_asker"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:id="@+id/tvLearnersTitle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="לומדים שלא שובצו"
                        android:textColor="@color/text_on_light_blue"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="12dp"
                        android:gravity="center" />

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/recyclerViewLearners"
                        android:layout_width="match_parent"
                        android:layout_height="600dp"
                        android:nestedScrollingEnabled="true"
                        tools:listitem="@layout/item_learner" />

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- Teachers Section -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardViewTeachers"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="@color/card_learn_giver"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:id="@+id/tvTeachersTitle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="מורים זמינים"
                        android:textColor="@color/text_on_light_green"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="12dp"
                        android:gravity="center" />

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/recyclerViewTeachers"
                        android:layout_width="match_parent"
                        android:layout_height="600dp"
                        android:nestedScrollingEnabled="true"
                        tools:listitem="@layout/item_teacher" />

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- Office Volunteers Section -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardViewOfficeVolunteers"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="@color/card_office_volunteer"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:id="@+id/tvOfficeVolunteersTitle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="מתנדבי משרד"
                        android:textColor="@color/text_on_light_amber"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="12dp"
                        android:gravity="center" />

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/recyclerViewOfficeVolunteers"
                        android:layout_width="match_parent"
                        android:layout_height="600dp"
                        android:nestedScrollingEnabled="true"
                        tools:listitem="@layout/item_user" />

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- Food Volunteers Section -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardViewFoodVolunteers"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="@color/card_food_volunteer"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:id="@+id/tvFoodVolunteersTitle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="מתנדבי מזון"
                        android:textColor="@color/text_on_light_purple"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="12dp"
                        android:gravity="center" />

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/recyclerViewFoodVolunteers"
                        android:layout_width="match_parent"
                        android:layout_height="600dp"
                        android:nestedScrollingEnabled="true"
                        tools:listitem="@layout/item_user" />

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- Supervisors Section -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardViewSupervisors"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="@color/card_supervisor"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:id="@+id/tvSupervisorsTitle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="מפקחים"
                        android:textColor="@color/text_on_light_pink"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="12dp"
                        android:gravity="center" />

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/recyclerViewSupervisors"
                        android:layout_width="match_parent"
                        android:layout_height="600dp"
                        android:nestedScrollingEnabled="true"
                        tools:listitem="@layout/item_user" />

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- Group Coordinators Section -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardViewGroupCoordinators"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/card_group_coordinator"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:id="@+id/tvGroupCoordinatorsTitle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="רכזי קבוצות"
                        android:textColor="@color/text_on_light_cyan"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="12dp"
                        android:gravity="center" />

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/recyclerViewGroupCoordinators"
                        android:layout_width="match_parent"
                        android:layout_height="600dp"
                        android:nestedScrollingEnabled="true"
                        tools:listitem="@layout/item_user" />

                </LinearLayout>

            </androidx.cardview.widget.CardView>

        </LinearLayout>

    </ScrollView>

</layout>
