<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    app:cardBackgroundColor="@color/surface_color"
    app:cardCornerRadius="8dp"
    app:cardElevation="2dp"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?android:attr/selectableItemBackground">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <TextView
                android:id="@+id/tvTeacherName"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="שם המורה"
                android:textColor="@color/secondary_color"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvTeacherCity"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="עיר"
                android:textColor="@color/white"
                android:textSize="14sp"
                android:background="@drawable/rounded_background"
                android:backgroundTint="@color/secondary_color"
                android:paddingHorizontal="8dp"
                android:paddingVertical="4dp" />

        </LinearLayout>

        <TextView
            android:id="@+id/tvTeacherSubjects"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="מקצועות: גמרא, הלכה, פילוסופיה"
            android:textColor="@color/text_primary"
            android:textSize="14sp"
            android:layout_marginBottom="4dp" />

        <TextView
            android:id="@+id/tvTeacherSchedule"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="זמנים: ראשון-חמישי 18:00-23:00"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:layout_marginBottom="4dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tvTeacherExperience"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="15 שנות הוראה"
                android:textColor="@color/text_secondary"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/tvTeacherCapacity"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="2/5 תלמידים"
                android:textColor="@color/white"
                android:textSize="12sp"
                android:background="@drawable/rounded_background"
                android:backgroundTint="@color/success_color"
                android:paddingHorizontal="6dp"
                android:paddingVertical="2dp" />

        </LinearLayout>

    </LinearLayout>

</androidx.cardview.widget.CardView>