<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <!-- Required for showing push notifications on Android 13+ -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Tachlit">

        <activity
            android:name=".SplashActivity"
            android:exported="true"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.Tachlit.NoActionBar">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".MainActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.Tachlit.NoActionBar" />

        <activity
            android:name=".LearnAskerActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:parentActivityName=".MainActivity" />

        <activity
            android:name=".LearnGiverActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:parentActivityName=".MainActivity" />

        <activity
            android:name=".OfficeVolunteerActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:parentActivityName=".MainActivity" />

        <activity
            android:name=".FoodVolunteerActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:parentActivityName=".MainActivity" />

        <activity
            android:name=".SupervisorActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:parentActivityName=".MainActivity" />

        <activity
            android:name=".GroupCoordinatorActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:parentActivityName=".MainActivity" />

        <activity
            android:name=".DonationsActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.Tachlit.NoActionBar"
            android:parentActivityName=".MainActivity" />

        <activity
            android:name=".SupervisorManagementActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:parentActivityName=".SupervisorActivity" />

        <activity
            android:name=".SupervisorSendNotificationActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.Tachlit.NoActionBar"
            android:parentActivityName=".SupervisorActivity" />

        <activity
            android:name=".RoleHomeActivity"
            android:exported="false"
            android:screenOrientation="portrait" />

        <!-- Firebase Cloud Messaging service -->
        <service
            android:name=".notifications.TachlitFirebaseMessagingService"
            android:exported="false">
            <intent-filter>
                <action android:name="com.google.firebase.MESSAGING_EVENT" />
            </intent-filter>
        </service>

        <!-- Default channel used when data-only messages arrive -->
        <meta-data
            android:name="com.google.firebase.messaging.default_notification_channel_id"
            android:value="tachlit_default" />

    </application>

</manifest>
